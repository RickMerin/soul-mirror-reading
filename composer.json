{
  "name": "soul-mirror/soul-mirror-reading",
  "description": "Soul Mirror Reading — PHP backend for tarot + Kit (cPanel/WAMP)",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.9",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit"
  }
}
