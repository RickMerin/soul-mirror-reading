# Document root should point to this `public/` directory.

# Routes `/api/reading` to the PHP handler (same URL the SPA uses).

# Do not place secrets, .env, or Composer metadata in this tree.

DirectoryIndex index.php index.html

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # HTTP → HTTPS (skip plain HTTP on local dev; honor reverse-proxy TLS via X-Forwarded-Proto)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block env files and editor/DB backup artifacts if ever deployed here by mistake
    # (Do not use a blanket "dotfile" rule: /.well-known is used for TLS and other verification.)
    RewriteRule ^\.env - [F,L]
    RewriteRule \.(bak|old|swp|sql)$ - [F,L]

    # Old static URLs → PHP pages (cache-busted CSS)
    RewriteRule ^thankyou\.html$ thankyou.php [L,R=301]
    RewriteRule ^sales-page\.html$ sales-page.php [L,R=301]
    RewriteRule ^downsell-ds1\.php$ downsell-1.php [L,R=301]

    RewriteRule ^api/reading$ api/reading.php [L]
    RewriteRule ^api/clickbank-ins$ api/clickbank-ins.php [L]

    # Legacy /v2/ funnel (removed) → root public pages
    RewriteRule ^v2/?$ / [R=301,L]
    RewriteRule ^v2/index\.php$ / [R=301,L]
    RewriteRule ^v2/sales\.php$ /sales.php [R=301,L]
    RewriteRule ^v2/thankyou\.php$ /thankyou.php [R=301,L]
    RewriteRule ^v2/unlock-reading\.php$ /unlock-reading.php [R=301,L]

    # When docroot is above public/, browsers may still hit .../public/v2/ — send to root funnel
    RewriteCond %{REQUEST_URI} ^/public/v2/index\.php$
    RewriteRule .* / [R=301,L]

    RewriteCond %{REQUEST_URI} ^/public/v2/sales\.php$
    RewriteRule .* /sales.php [R=301,L]

    RewriteCond %{REQUEST_URI} ^/public/v2/thankyou\.php$
    RewriteRule .* /thankyou.php [R=301,L]

    RewriteCond %{REQUEST_URI} ^/public/v2/unlock-reading\.php$
    RewriteRule .* /unlock-reading.php [R=301,L]

    RewriteCond %{REQUEST_URI} ^/public/v2/?$
    RewriteRule .* / [R=301,L]

    RewriteCond %{THE_REQUEST} \s[^\s]*/public/v2/index\.php
    RewriteCond %{REQUEST_URI} ^(.+)/public/v2/index\.php$
    RewriteRule .* %1/ [R=301,L]

    RewriteCond %{THE_REQUEST} \s[^\s]*/public/v2/sales\.php
    RewriteCond %{REQUEST_URI} ^(.+)/public/v2/sales\.php$
    RewriteRule .* %1/sales.php [R=301,L]

    RewriteCond %{THE_REQUEST} \s[^\s]*/public/v2/thankyou\.php
    RewriteCond %{REQUEST_URI} ^(.+)/public/v2/thankyou\.php$
    RewriteRule .* %1/thankyou.php [R=301,L]

    RewriteCond %{THE_REQUEST} \s[^\s]*/public/v2/unlock-reading\.php
    RewriteCond %{REQUEST_URI} ^(.+)/public/v2/unlock-reading\.php$
    RewriteRule .* %1/unlock-reading.php [R=301,L]

    RewriteCond %{THE_REQUEST} \s[^\s]*/public/v2/?[\s?]
    RewriteCond %{REQUEST_URI} ^(.+)/public/v2/?$
    RewriteRule .* %1/ [R=301,L]

</IfModule>

<IfModule mod_headers.c>
    # HSTS only applies on HTTPS responses (env=HTTPS set by mod_ssl)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Cross-Origin-Opener-Policy "same-origin"
    # ConverteAI/VTurb player uses eval; Google Fonts, jsDelivr (GSAP), cdnjs (member PDF.js),
    # ClickBank checkout, Kit/ConvertKit embed on unlock-reading.
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net https://*.clarity.ms https://*.kit.com https://*.convertkit.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.kit.com https://*.convertkit.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net https://*.b-cdn.net https://*.vturb.net https://*.vturb.com https://sentry.io https://*.sentry.io https://fonts.googleapis.com https://www.clkbank.com https://rebornf.pay.clickbank.net https://*.clarity.ms https://c.bing.com https://api.kit.com https://*.kit.com https://*.convertkit.com; frame-src 'self' https://scripts.converteai.net https://*.converteai.net https://*.vturb.com.br https://vturb.com.br https://*.vturb.net https://*.vturb.com https://*.b-cdn.net https://rebornf.pay.clickbank.net https://www.clkbank.com https://orderformssl.com https://*.orderformssl.com https://*.kit.com https://*.convertkit.com; worker-src 'self' blob: https://cdnjs.cloudflare.com; media-src 'self' blob: https: data:; base-uri 'self'; form-action 'self' https://rebornf.pay.clickbank.net https://www.clkbank.com https://*.kit.com https://*.convertkit.com; frame-ancestors 'self'"
</IfModule>
