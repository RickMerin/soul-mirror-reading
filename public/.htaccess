# Document root should point to this `public/` directory.

# Routes `/api/reading` to the PHP handler (same URL the SPA uses).

# Do not place secrets, .env, or Composer metadata in this tree.

DirectoryIndex index.php index.html

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # HTTP â†’ HTTPS (skip plain HTTP on local dev; honor reverse-proxy TLS via X-Forwarded-Proto)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block env files and editor/DB backup artifacts if ever deployed here by mistake
    # (Do not use a blanket "dotfile" rule: /.well-known is used for TLS and other verification.)
    RewriteRule ^\.env - [F,L]
    RewriteRule \.(bak|old|swp|sql)$ - [F,L]

    # Old static URLs â†’ PHP pages (cache-busted CSS)
    RewriteRule ^thankyou\.html$ thankyou.php [L,R=301]
    RewriteRule ^sales-page\.html$ sales-page.php [L,R=301]
    RewriteRule ^downsell-ds1\.php$ downsell-1.php [L,R=301]

    RewriteRule ^api/reading$ api/reading.php [L]
    RewriteRule ^api/clickbank-ins$ api/clickbank-ins.php [L]

</IfModule>

<IfModule mod_headers.c>
    # HSTS only applies on HTTPS responses (env=HTTPS set by mod_ssl)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Cross-Origin-Opener-Policy "same-origin"
    # Enforcing policy aligned with local dev (no third-party CSP): ConverteAI/VTurb player uses eval;
    # Google Fonts, jsDelivr (GSAP), cdnjs (member PDF.js), ClickBank checkout.
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net https://*.b-cdn.net https://*.vturb.net https://fonts.googleapis.com https://www.clkbank.com https://rebornf.pay.clickbank.net; frame-src 'self' https://scripts.converteai.net https://*.converteai.net https://*.vturb.com.br https://vturb.com.br https://*.vturb.net https://*.b-cdn.net https://rebornf.pay.clickbank.net https://www.clkbank.com https://orderformssl.com https://*.orderformssl.com; worker-src 'self' blob: https://cdnjs.cloudflare.com; media-src 'self' blob: https: data:; base-uri 'self'; form-action 'self' https://rebornf.pay.clickbank.net https://www.clkbank.com; frame-ancestors 'self'"
</IfModule>
