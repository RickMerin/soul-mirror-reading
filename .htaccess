# Use when the Apache document root is the repository root (not `public/`).
# Prefer pointing the vhost or subdomain document root to `public/` in production.
#
# Without the rules below, Apache would serve real files at this directory (e.g.
# composer.json, .env.example) before the rewrite to public/ runs.

Options -Indexes

# ------------------------
# Basic HTTP Authentication for TEST ENV ONLY
# Enable basic auth on https://test.soulmirrorreading.com/ by uncommenting below.
#
# Step 1: Create your password file (if you haven't already):
#   htpasswd -c /absolute/path/to/.htpasswd youruser
#
# Step 2: Uncomment the block below and set the correct AuthUserFile absolute path.
#
<If "%{HTTP_HOST} == 'test.soulmirrorreading.com'">
    AuthType Basic
    AuthName "Restricted Access — Soul Mirror Reading TEST"
    AuthUserFile /home/soulmirrorreadin/.htpasswd
    Require valid-user
</If>
# ------------------------

<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTP → HTTPS (skip local dev; honor reverse-proxy TLS)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # If the request is '/' serve the main reading page (PHP provides CSS cache-bust).
    RewriteRule ^$ public/index.php [L]

    RewriteRule ^thankyou\.html$ public/thankyou.php [L,R=301]
    RewriteRule ^sales-page\.html$ public/sales-page.php [L,R=301]

    # --- Clean URLs for member: no .php, no index in URL ---
    # Map /member or /member/ to public/member/index.php
    RewriteRule ^member/?$ public/member/index.php [L]

    # Redirect direct access to index.php to clean URL.
    # Capture the URL-space prefix from REQUEST_URI so the 301 target is a real URL path.
    # A bare relative target like `member` would make Apache resolve against the filesystem
    # directory on Windows/WAMP and produce `http://host/C:/wamp64/www/.../member`.
    RewriteCond %{REQUEST_URI} ^(.*)/member/index\.php$
    RewriteRule ^member/index\.php$ %1/member [R=301,L]

    RewriteCond %{REQUEST_URI} ^(.*)/member/login\.php$
    RewriteRule ^member/login\.php$ %1/login.php [R=301,L]

    RewriteCond %{REQUEST_URI} ^(.*)/member/logout\.php$
    RewriteRule ^member/logout\.php$ %1/logout.php [R=301,L]

    # --- Block sensitive paths and files (403; must run before static file delivery) ---
    # (No mandatory /public/ -> / redirect here: absolute redirects break subdirectory installs.
    # Prefer vhost docroot = public/ or link without the /public/ segment.)
    RewriteRule ^\.env - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^phpunit\.xml$ - [F,L]
    RewriteRule ^package(-lock)?\.json$ - [F,L]
    RewriteRule ^\.phpunit\.cache(/|$) - [F,L]
    RewriteRule ^(src|tests|vendor|docs|\.git|\.github|\.cursor)(/|$) - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^(\.gitignore|\.gitattributes)$ - [F,L]
    RewriteRule ^README\.md$ - [F,L]

    RewriteRule ^api/reading$ public/api/reading.php [L]

    # Rewrite all other requests that aren't actual files or directories to the public folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net https://*.clarity.ms https://*.kit.com https://*.convertkit.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.kit.com https://*.convertkit.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://scripts.converteai.net https://*.converteai.net https://*.b-cdn.net https://*.vturb.net https://*.vturb.com https://sentry.io https://*.sentry.io https://fonts.googleapis.com https://www.clkbank.com https://rebornf.pay.clickbank.net https://*.clarity.ms https://c.bing.com https://api.kit.com https://*.kit.com https://*.convertkit.com; frame-src 'self' https://scripts.converteai.net https://*.converteai.net https://*.vturb.com.br https://vturb.com.br https://*.vturb.net https://*.vturb.com https://*.b-cdn.net https://rebornf.pay.clickbank.net https://www.clkbank.com https://orderformssl.com https://*.orderformssl.com https://*.kit.com https://*.convertkit.com; worker-src 'self' blob: https://cdnjs.cloudflare.com; media-src 'self' blob: https: data:; base-uri 'self'; form-action 'self' https://rebornf.pay.clickbank.net https://www.clkbank.com https://*.kit.com https://*.convertkit.com; frame-ancestors 'self'"
</IfModule>
