# AstrologyAPI (https://json.astrologyapi.com) — Basic auth
ASTRO_USER_ID=
ASTRO_API_KEY=

# Kit (ConvertKit) API v4 — https://api.kit.com/v4/
KIT_API_KEY=
# Tag applied after subscriber upsert (triggers email automation)
KIT_TAG_NAME=soul-mirror-leads

# Optional: pipeline diagnostics to storage/logs/pipeline.log (no secrets/PII)
# SOUL_MIRROR_PIPELINE_LOG=1
# Optional absolute path; default is <project>/storage/logs/pipeline.log
# SOUL_MIRROR_LOG_PATH=
