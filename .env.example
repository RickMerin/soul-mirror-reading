# Copy to `.env` and fill in values. Never commit `.env`.

# AstrologyAPI (https://www.astrologyapi.com/) — Basic auth
ASTRO_USER_ID=
ASTRO_API_KEY=

# Kit (ConvertKit) API v4 — https://developers.kit.com/
KIT_API_KEY=

# Optional; tag applied after upsert (default: soul-mirror-leads)
# KIT_TAG_NAME=soul-mirror-leads

# Optional: load YOUR Kit form embed on the landing page (must be the same Kit account as KIT_API_KEY).
# Get the script URL from Kit → Grow → Landing pages & forms → your form → HTML embed.
# Example: script src https://yourname.kit.com/abc123def/index.js → KIT_EMBED_SUBDOMAIN=yourname  KIT_EMBED_FORM_UID=abc123def
KIT_EMBED_SUBDOMAIN=astrologyvault
KIT_EMBED_FORM_UID=87bff9e0cc

# Optional; default 3000
PORT=3000
