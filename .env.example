# AstrologyAPI (https://json.astrologyapi.com) — Basic auth
ASTRO_USER_ID=
ASTRO_API_KEY=

# Kit (ConvertKit) API v4 — https://api.kit.com/v4/
KIT_API_KEY=
# Tag applied after subscriber upsert (triggers email automation)
KIT_TAG_NAME=soul-mirror-leads
# Tag for ClickBank buyers when INS line items have no SKU (defaults to KIT_TAG_NAME if unset)
KIT_TAG_NAME_BUYER=

# Optional: pipeline diagnostics to storage/logs/pipeline.log (no secrets/PII)
# SOUL_MIRROR_PIPELINE_LOG=1
# After a test unlock submit: php scripts/verify-reading-pipeline-log.php (expects kit: lines in the log tail)
# Optional absolute path; default is <project>/storage/logs/pipeline.log
# SOUL_MIRROR_LOG_PATH=

# TLS: on Windows/WAMP, cURL error 60 → use a CA bundle. Either:
# - Download https://curl.se/ca/cacert.pem to storage/cacert.pem (auto-detected), or
# - Set php.ini curl.cainfo / openssl.cafile, or
# SSL_CAFILE=C:/path/to/cacert.pem

# Optional: Slack Incoming Webhook for ClickBank INS (decrypted payload + txn type in a Block Kit table)
# CLICKBANK_INS_SLACK_WEBHOOK_URL=

# Database (lead capture, purchases, member login)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# Dev-only: fake ClickBank purchase (smr-1 + srp-1 Soul Ritual) for local member login — php scripts/seed-dev-purchase.php
# ALLOW_DEV_PURCHASE_SEED=1
# DEV_SEED_BUYER_EMAIL=dev-buyer@example.com
# DEV_SEED_NO_PURCHASE_EMAIL=dev-nopurchase@example.com
# DEV_SEED_REFUNDED_EMAIL=dev-refunded@example.com

# Public base URL for application routing
APP_BASE_URL=http://localhost/soul-mirror-reading
# OTO/downsell pages use image paths `../frontend/images/ups-downs/` (sibling of `public/`). If the web root is only `public/`, add an Apache Alias for `/frontend` → project `frontend/` or copy `frontend/images/ups-downs` under `public/`.

# Member portal (public/member/index.php) — optional asset URLs and Soul Ritual (OTO) SKU
# Primary funnel product SKU is smr-1 (see public/sales.php, scripts/seed-dev-purchase.php).
# MEMBER_CLKBANK_NOTICE=Billing: CLKBANK · REBORNF
# MEMBER_RITUAL_SKU=srp-1
# When MEMBER_RITUAL_SKU is set (matches upsell-1 product id), buyers with that sku in an approved purchase see the full Soul Ritual library. Dev seed includes srp-1 when MEMBER_RITUAL_SKU=srp-1.
# Build script scripts/build-oto-pages.php — absolute path to exported upsell-oto1.html (optional; else ../Downloads/… or %USERPROFILE%/Downloads/…)
# OTO_BUILD_UPSELL_HTML=C:/Users/You/Downloads/soul-ritual-upsell-downsell-2026-04-23/upsell-oto1.html
# OTO / downsell (public/upsell-1.php, public/downsell-1.php) — set full ClickBank URLs; coupons FOUNDING100 / EXTRA30 are configured in ClickBank
# UPSELL_OTO_CHECKOUT_URL=https://rebornf.pay.clickbank.net/?cbitems=YOUR_OTO_SKU&couppon=FOUNDING100
# Downsell ($67); falls back to empty href="#" if unset
# DOWNSELL_CHECKOUT_URL=https://rebornf.pay.clickbank.net/?cbitems=YOUR_DS_SKU&couppon=EXTRA30
# Back-compat alias if UPSELL_OTO_CHECKOUT_URL is not set
# MEMBER_OTO_CHECKOUT_URL=https://YOURVENDOR.pay.clickbank.net/?cbitems=YOUR_OTO_SKU&vtid=membership
# MEMBER_URL_READING_PDF=
# MEMBER_URL_BONUS_COMPANION=
# MEMBER_URL_BONUS_SHIFT_TRACKER=
# MEMBER_URL_BONUS_ROOT_CAUSE=
# MEMBER_URL_BONUS_MEDITATION_AUDIO=
# MEMBER_URL_RITUAL_REPORT1=
# MEMBER_URL_RITUAL_REPORT2=
# MEMBER_URL_RITUAL_REPORT3=
# MEMBER_URL_RITUAL_WORKBOOK=
